# Copy this file to .env and fill in your values
DATABASE_URL=postgresql://user:password@localhost:5432/compressoriq
UPLOAD_DIR=data/uploads
SOURCE_DATA_DIR=
LOG_LEVEL=INFO

# Optional — when set, mutating API routes require header: X-API-Key: <value> or Authorization: Bearer <value>
# Frontend: set NEXT_PUBLIC_API_KEY to the same value (see frontend env).
API_KEY=

# Auto-create system work orders when running health assessment (high/critical alerts by default)
AUTO_WORK_ORDERS_FROM_HEALTH_ALERTS=true
HEALTH_ALERT_WORK_ORDER_SEVERITIES=high,critical

# OpenAI — set your key to enable LLM-powered recommendations
# Leave blank to fall back to the rule-based engine
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
